{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"sourceMap": false,
		"noEmit": false,
		"declaration": true,
		"declarationDir": "dist",
		"noUncheckedIndexedAccess": true
	},
	"include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
	"exclude": ["node_modules"]
}
