{
  "name": "suncalc3-ts",
  "version": "2.1.0",
  "description": "A tiny TypeScript library for calculating sun/moon positions and phases.",
  "author": "Vladimir Agafonkin",
  "contributors": [
    "Robert Gester (https://github.com/hypnos3)",
    "Adrien (https://github.com/e-adrien)",
    "Harold Martin (https://github.com/hbmartin)"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/suncalc3-ts.git"
  },
  "homepage": "https://github.com/hbmartin/suncalc3-ts#readme",
  "bugs": {
    "url": "https://github.com/hbmartin/suncalc3-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs": "typedoc",
    "eslint-check": "eslint .",
    "eslint-fix": "eslint . --fix",
    "prettier-check": "prettier --check .",
    "prettier-fix": "prettier --write ."
  },
  "files": [
    "src/**/*",
    "dist/**/*"
  ],
  "keywords": [
    "sun",
    "moon",
    "astronomy",
    "math",
    "calculation",
    "sunrise",
    "sunset",
    "twilight",
    "golden hour",
    "blue hour",
    "moon phase",
    "illumination",
    "typescript"
  ],
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tsconfig/node20": "^20.1.5",
    "@types/node": "^22.15.24",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typedoc": "^0.28.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.33.0",
    "vitest": "^3.1.4"
  }
}
