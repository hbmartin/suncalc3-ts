{
  "name": "suncalc3-ts",
  "version": "2.1.0",
  "description": "A tiny TypeScript library for calculating sun/moon positions and phases.",
  "author": "Vladimir Agafonkin",
  "contributors": [
    "Robert Gester (https://github.com/hypnos3)",
    "Adrien (https://github.com/e-adrien)",
    "Harold Martin (https://github.com/hbmartin)"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/suncalc3-ts.git"
  },
  "homepage": "https://github.com/hbmartin/suncalc3-ts#readme",
  "bugs": {
    "url": "https://github.com/hbmartin/suncalc3-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs": "typedoc",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "verify:package": "publint && attw --pack . --profile esm-only",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build && pnpm run verify:package"
  },
  "files": [
    "src/**/*",
    "dist/**/*"
  ],
  "keywords": [
    "sun",
    "moon",
    "astronomy",
    "math",
    "calculation",
    "sunrise",
    "sunset",
    "twilight",
    "golden hour",
    "blue hour",
    "moon phase",
    "illumination",
    "typescript"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "publint": "^0.3.21",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
